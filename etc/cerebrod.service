[Unit]                               
Description=Cerebrod daemon          
After=syslog.target network.target   
                                      
[Service]                            
Type=simple
ExecStart=/usr/sbin/cerebrod -f
ExecReload=/bin/kill -HUP $MAINPID   
KillMode=process                     
User=root
Group=root
Restart=on-failure                   
RestartSec=5s                        
                                      
[Install]                            
WantedBy=multi-user.target           
